# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: https://app.supabase.com → your project → Settings → API

# Public URL of your Supabase project
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Public (anon) key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — keep this SECRET, only used in API routes (server-side)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin dashboard password (default: jobingen-admin-2026)
ADMIN_PASSWORD=jobingen-admin-2026
